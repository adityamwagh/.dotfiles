{
  "cleanupPeriodDays": 90,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "Skill(code-review:code-review)",
      "Skill(code-review:code-review:*)",
      "Read(//home/aditya/**)",
      "Bash(pip show *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git fetch *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git remote *)",
      "Bash(git stash)",
      "Bash(git stash pop)",
      "Bash(gs)",
      "Bash(gd)",
      "Bash(gd *)",
      "Bash(gf)",
      "Bash(gl)",
      "Bash(gll)",
      "Bash(gla)",
      "Bash(gstl)",
      "Bash(uv run *)",
      "Bash(uv sync *)",
      "Bash(uv pip show *)",
      "Bash(uv tool list)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh run *)",
      "Bash(gh api *)",
      "Bash(pre-commit run --color=always --all-files)",
      "Bash(pcra)",
      "Bash(ll)",
      "Bash(ll *)",
      "Bash(l)",
      "Bash(l *)",
      "Bash(la)",
      "Bash(la *)",
      "Bash(lsd)",
      "Bash(lt)",
      "Bash(tree)",
      "Bash(tree *)",
      "Bash(find *)",
      "Bash(rg *)",
      "Bash(bun run *)",
      "Bash(bun install)",
      "Bash(brew list)",
      "Bash(brew info *)",
      "Bash(act *)",
      "Bash(cargo build *)",
      "Bash(cargo test *)",
      "Bash(cargo check *)",
      "Bash(cargo clippy *)",
      "Bash(gh repo view *)",
      "Bash(gh workflow *)",
      "Bash(uvx *)",
      "Bash(which *)",
      "Bash(ls *)",
      "Bash(brew tap)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Write(/etc/**)",
      "Write(.env*)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys,json,re; d=json.load(sys.stdin); c=d.get('content',''); patterns=['AKIA[A-Z0-9]{16}','ghp_[A-Za-z0-9]{36}','-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY']; found=[p for p in patterns if re.search(p,c)]; print(json.dumps({'permissionDecision':'deny','permissionDecisionReason':'Secret pattern detected: '+str(found)}) if found else '{}')\""
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys,json,re; d=json.load(sys.stdin); c=d.get('new_string',''); patterns=['AKIA[A-Z0-9]{16}','ghp_[A-Za-z0-9]{36}','-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY']; found=[p for p in patterns if re.search(p,c)]; print(json.dumps({'permissionDecision':'deny','permissionDecisionReason':'Secret pattern detected: '+str(found)}) if found else '{}')\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys,json,datetime; d=json.load(sys.stdin); cmd=d.get('input',{}).get('command',''); open('/tmp/claude-bash-audit.log','a').write(datetime.datetime.now().isoformat()+' '+cmd[:200]+'\\n') if any(x in cmd for x in ['git push','git commit','gh pr create','gh pr merge']) else None\"",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "cship"
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "claude-code-setup@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "github@claude-plugins-official": false,
    "greptile@claude-plugins-official": false,
    "hookify@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "juliusbrussee/caveman"
      }
    }
  },
  "effortLevel": "medium",
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "custom:tango-dark",
  "preferredNotifChannel": "ghostty",
  "autoCompactEnabled": true,
  "autoScrollEnabled": true,
  "fileCheckpointingEnabled": true,
  "showTurnDuration": true,
  "showMessageTimestamps": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
