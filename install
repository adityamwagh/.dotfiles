#!/usr/bin/env bash
set -euo pipefail

DOTFILES_DIR="$(cd "$(dirname "$0")" && pwd)"
DOTBOT_DIR="$DOTFILES_DIR/dotbot"

if [ ! -x "$DOTBOT_DIR/bin/dotbot" ] || [ ! -f "$DOTFILES_DIR/dotbot-brew/brew.py" ] ||
  [ ! -f "$DOTFILES_DIR/dotbot-unipkg/unipkg.py" ]; then
  git -C "$DOTFILES_DIR" submodule update --init --recursive
fi

"$DOTBOT_DIR/bin/dotbot" -d "$DOTFILES_DIR" -c "$DOTFILES_DIR/install.conf.yaml" \
  --plugin-dir "$DOTFILES_DIR/dotbot-brew" \
  --plugin-dir "$DOTFILES_DIR/dotbot-unipkg" "$@"
